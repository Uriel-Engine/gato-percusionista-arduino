// ================= FUNCIONES =================

void drawImage(const unsigned char *img) {
  display.clearDisplay();
  display.drawBitmap(0, 0, img, 128, 64, WHITE);
  display.display();
}

void playSound(int freq) {
  tone(BUZZER, freq);
  soundStart = millis();
  soundPlayed = true;
}

void updateSound() {
  if (soundPlayed && millis() - soundStart >= SOUND_DURATION) {
    noTone(BUZZER);
    soundPlayed = false;
  }
}

// ================= SETUP =================
void setup() {
  pinMode(TOUCH1, INPUT);
  pinMode(TOUCH2, INPUT);
  pinMode(BUZZER, OUTPUT);

  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.clearDisplay();

  drawImage(img1);
}

// ================= LOOP =================
void loop() {

  bool t1 = digitalRead(TOUCH1);
  bool t2 = digitalRead(TOUCH2);

  unsigned long now = millis();

  // ================= DETECCIÓN CON TOLERANCIA =================
  if (t1 || t2) {
    if (!waitingCombo) {
      waitingCombo = true;
      firstTouchTime = now;
    }

    if (now - firstTouchTime > COMBO_TOLERANCE) {
      if (t1 && t2) currentState = BOTH;
      else if (t1) currentState = TOUCH_1;
      else if (t2) currentState = TOUCH_2;
    }
  } else {
    currentState = IDLE;
    waitingCombo = false;
  }

  // ================= CAMBIO DE ESTADO =================
  if (currentState != lastState) {

    switch (currentState) {

      case IDLE:
        drawImage(img1);
        noTone(BUZZER);
        soundPlayed = false;
        break;

      case TOUCH_1:
        drawImage(img2);
        playSound(FREQ_LOW);
        break;

      case TOUCH_2:
        drawImage(img3);
        playSound(FREQ_HIGH);
        break;

      case BOTH:
        drawImage(img4);
        playSound(FREQ_COMBO);
        break;
    }

    lastState = currentState;
  }

  // ================= CONTROL DURACIÓN SONIDO =================
  updateSound();
}
